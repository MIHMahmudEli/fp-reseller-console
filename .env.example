# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- App: FlashProxy upstream ---
# Base URL for the FlashProxy Reseller API. Use the sandbox for local dev.
# Live:    https://rapi.flashproxy.com/api/v1
# Sandbox: https://rapi.flashproxy.com/sandbox/api/v1
FLASHPROXY_API_BASE_URL=https://rapi.flashproxy.com/api/v1

# --- Session ---
# 32+ char random secret used to encrypt the iron-session cookie.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# --- Admin (audit viewer) ---
# Operator password for the /admin audit log viewer. If unset, /admin is disabled.
ADMIN_TOKEN=replace_with_a_random_admin_password

# --- Database (Supabase Postgres) ---
# Runtime uses the POOLED connection (port 6543, ?pgbouncer=true).
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
# Migrations use the DIRECT connection (port 5432).
DIRECT_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# --- Exploration scripts only (scripts/*.mjs) ---
# Not used by the app itself; the app gets the key from the user's login.
FLASHPROXY_API_KEY=fp_test_or_fp_live_key_here
